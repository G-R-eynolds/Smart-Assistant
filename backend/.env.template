# Job Tools Environment Variables Template
# Copy this to your .env file and fill in your actual values

# Airtable Configuration
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
AIRTABLE_TABLE_NAME=Jobs

# Google API (already configured for Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Instructions:
# 1. Get your Airtable API key from: https://airtable.com/create/tokens
# 2. Get your Airtable Base ID from the URL when viewing your base
# 3. Create a table named "Jobs" with these columns:
#    - Job Title (Single line text)
#    - Company (Single line text) 
#    - Job URL (URL)
#    - Status (Single select: To Apply, Applied, Interview, Rejected, Offer)
#    - Date Added (Date)
#    - Notes (Long text)
#    - Salary Range (Single line text)
#    - Location (Single line text)
#    - Application Deadline (Date)
